<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.csust.hackathonserver.mapper.RegistrationsMapper">

    <resultMap id="BaseResultMap" type="com.csust.hackathonserver.pojo.Registrations">
            <id property="id" column="id" />
            <result property="eventId" column="event_id" />
            <result property="userId" column="user_id" />
            <result property="registrationType" column="registration_type" />
            <result property="teamName" column="team_name" />
            <result property="contactName" column="contact_name" />
            <result property="contactPhone" column="contact_phone" />
            <result property="contactEmail" column="contact_email" />
            <result property="trackId" column="track_id" />
            <result property="status" column="status" />
            <result property="payloadJson" column="payload_json" />
            <result property="aiTagsJson" column="ai_tags_json" />
            <result property="aiSummary" column="ai_summary" />
            <result property="reviewNote" column="review_note" />
            <result property="reviewedBy" column="reviewed_by" />
            <result property="reviewedAt" column="reviewed_at" />
            <result property="createdAt" column="created_at" />
            <result property="updatedAt" column="updated_at" />
    </resultMap>

    <sql id="Base_Column_List">
        id,event_id,user_id,registration_type,team_name,contact_name,
        contact_phone,contact_email,track_id,status,payload_json,
        ai_tags_json,ai_summary,review_note,reviewed_by,reviewed_at,
        created_at,updated_at
    </sql>

    <!-- 插入报名记录，自动回填主键 id -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into registrations(event_id, user_id, registration_type, team_name,
            contact_name, contact_phone, contact_email, track_id, status, payload_json, created_at, updated_at)
        values(#{eventId}, #{userId}, #{registrationType}, #{teamName},
            #{contactName}, #{contactPhone}, #{contactEmail}, #{trackId}, #{status}, #{payloadJson}, #{createdAt}, #{updatedAt})
    </insert>

    <!-- 根据 eventId + userId 查询报名记录，用于防重复报名 -->
    <select id="getByEventIdAndUserId" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from registrations
        where event_id = #{eventId} and user_id = #{userId}
    </select>
</mapper>
