<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.csust.hackathonserver.mapper.UsersMapper">

    <resultMap id="BaseResultMap" type="com.csust.hackathonserver.pojo.Users">
            <id property="id" column="id" />
            <result property="role" column="role" />
            <result property="name" column="name" />
            <result property="email" column="email" />
            <result property="phone" column="phone" />
            <result property="passwordHash" column="password_hash" />
            <result property="avatarUrl" column="avatar_url" />
            <result property="status" column="status" />
            <result property="createdAt" column="created_at" />
            <result property="updatedAt" column="updated_at" />
    </resultMap>

    <sql id="Base_Column_List">
        id,role,name,email,phone,password_hash,
        avatar_url,status,created_at,updated_at
    </sql>
    <insert id="register">
        insert into
            users(name,phone,email,password_hash,created_at,updated_at,role)
           values(#{name},#{phone},#{email},#{passwordHash},#{createdAt},#{updatedAt},#{role})
    </insert>
    <select id="login" resultType="int">
        select count(*) from users where name=#{name} and password_hash=#{passwordHash}
    </select>
    <select id="getByAccount" resultType="com.csust.hackathonserver.pojo.Users">
        select * from users where phone=#{account} or email=#{account}
    </select>
</mapper>
